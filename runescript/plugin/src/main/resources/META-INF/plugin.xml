<idea-plugin>
    <id>com.os1.runescript</id>
    <name>RuneScript (OS1)</name>
    <vendor>OS1</vendor>

    <description><![CDATA[
        RuneScript language support for OS1 server scripts (.rs2) and
        clientscripts (.cs2): syntax highlighting, pack-backed symbol
        resolution, completion, Compile/Decompile actions, a .cs2asm
        assembly-listing file type, and a side-by-side source/assembly
        editor for clientscripts backed by the Rust toolchain.
    ]]></description>

    <dependencies>
        <plugin id="com.intellij.modules.lang"/>
    </dependencies>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="RuneScript"
            implementationClass="com.os1.runescript.plugin.lang.RuneScriptFileType"
            fieldName="INSTANCE"
            language="RuneScript"
            extensions="rs2;cs2"/>

        <lang.syntaxHighlighterFactory
            language="RuneScript"
            implementationClass="com.os1.runescript.plugin.highlight.RuneScriptSyntaxHighlighterFactory"/>

        <!-- Settings → Editor → Color Scheme → RuneScript (recolour all RS_* keys). -->
        <colorSettingsPage
            implementation="com.os1.runescript.plugin.highlight.RuneScriptColorSettingsPage"/>

        <lang.parserDefinition
            language="RuneScript"
            implementationClass="com.os1.runescript.plugin.psi.RuneScriptParserDefinition"/>

        <annotator
            language="RuneScript"
            implementationClass="com.os1.runescript.plugin.annotate.RuneScriptAnnotator"/>

        <!-- Real syntax/error highlighting for .rs2 via the shared frontend parser. -->
        <externalAnnotator
            language="RuneScript"
            implementationClass="com.os1.runescript.plugin.annotate.RuneScriptErrorAnnotator"/>

        <!-- Hover docs: show a symbol's kind + id (interface/var/config/command). -->
        <lang.documentationProvider
            language="RuneScript"
            implementationClass="com.os1.runescript.plugin.doc.RuneScriptDocumentationProvider"/>

        <!-- Ctrl-click: ~proc / @label jump to their [proc,name] / [label,name] header. -->
        <gotoDeclarationHandler
            implementation="com.os1.runescript.plugin.nav.RuneScriptGotoDeclarationHandler"/>
        <!-- Ctrl-click: a com_N value in a config jumps to its [com_N] section. -->
        <gotoDeclarationHandler
            implementation="com.os1.runescript.plugin.config.ConfigGotoDeclarationHandler"/>

        <completion.contributor
            language="RuneScript"
            implementationClass="com.os1.runescript.plugin.completion.RuneScriptCompletionContributor"/>

        <!-- Config text (interfaces/npc/loc/obj/seq/…) — key=value + sections. -->
        <fileType
            name="RsConfig"
            implementationClass="com.os1.runescript.plugin.config.ConfigFileType"
            fieldName="INSTANCE"
            language="RsConfig"
            extensions="if;npc;loc;obj;seq;flo;flu;idk;inv;spot;varbit;varp;enum"/>
        <lang.syntaxHighlighterFactory
            language="RsConfig"
            implementationClass="com.os1.runescript.plugin.config.ConfigSyntaxHighlighterFactory"/>
        <lang.parserDefinition
            language="RsConfig"
            implementationClass="com.os1.runescript.plugin.config.ConfigParserDefinition"/>
        <colorSettingsPage
            implementation="com.os1.runescript.plugin.config.ConfigColorSettingsPage"/>
        <completion.contributor
            language="RsConfig"
            implementationClass="com.os1.runescript.plugin.config.ConfigCompletionContributor"/>

        <!-- ClientScript assembly listings (.cs2asm) — the packer's faithful fallback
             format and the right-hand pane of the side-by-side cs2 editor. -->
        <fileType
            name="Cs2Asm"
            implementationClass="com.os1.runescript.plugin.asm.Cs2AsmFileType"
            fieldName="INSTANCE"
            language="Cs2Asm"
            extensions="cs2asm"/>

        <lang.syntaxHighlighterFactory
            language="Cs2Asm"
            implementationClass="com.os1.runescript.plugin.asm.Cs2AsmSyntaxHighlighterFactory"/>

        <lang.parserDefinition
            language="Cs2Asm"
            implementationClass="com.os1.runescript.plugin.asm.Cs2AsmParserDefinition"/>

        <!-- Side-by-side source + live assembly for structured .cs2 clientscripts. -->
        <fileEditorProvider
            implementation="com.os1.runescript.plugin.editor.Cs2PreviewEditorProvider"/>

        <!-- Rename refactoring for interface symbols (if_549 / if_549:com_2):
             updates interface.pack, the .if filename/section, and all refs. -->
        <renameHandler
            implementation="com.os1.runescript.plugin.refactor.RsInterfaceRenameHandler"/>
    </extensions>

    <actions>
        <action id="com.os1.runescript.CompileAction"
                class="com.os1.runescript.plugin.action.CompileScriptsAction"
                text="Compile RuneScript"
                description="Compile the RuneScript source set to a pack">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="com.os1.runescript.DecompileAction"
                class="com.os1.runescript.plugin.action.DecompileClientScriptAction"
                text="Decompile ClientScript..."
                description="Decompile a cs2 clientscript to source">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
